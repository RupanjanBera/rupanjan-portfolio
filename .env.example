# DeepSeek API key for Portfolio AI assistant (optional — local AI works without it)
# Get your key at: https://platform.deepseek.com/
# Copy this file to .env.local and add your key:
#   cp .env.example .env.local
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Static export (GitHub Pages) — uses instant portfolio-grounded AI, no API needed
# NEXT_PUBLIC_STATIC_EXPORT=true
# NEXT_PUBLIC_BASE_PATH=/rupanjan-portfolio

# Production API (Vercel free tier) — auto-used on GitHub Pages static export
# NEXT_PUBLIC_PORTFOLIO_AI_API_URL=https://portfolio-ai-api-omega.vercel.app/api/portfolio-ai

# GitHub Actions secrets for auto-deploy:
#   VERCEL_TOKEN, VERCEL_ORG_ID, VERCEL_PROJECT_ID, DEEPSEEK_API_KEY (on Vercel)
#   PORTFOLIO_AI_API_URL (optional override for the static site build)